generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                String    @id @default(cuid())
  username          String    @unique
  passwordHash      String
  email             String?   @unique
  lineUserId        String?
  lineBindCode      String?
  lineBindExpiry    DateTime?
  discordUserId     String?
  discordBindCode   String?
  discordBindExpiry DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  rules             Rule[]
  tradeActivities   TradeActivity[]

  // ─── Subscription plan & daily usage quotas ──────────────────────────────
  plan              String    @default("FREE")   // "FREE" | "PLAN_399" | "PLAN_799"
  rulesToday        Int       @default(0)        // AI rules created since usageResetAt
  chatToday         Int       @default(0)        // conversational inputs sent since usageResetAt
  usageResetAt      DateTime  @default(now())     // last time the daily counters were reset
}

model Rule {
  id             String    @id @default(cuid())
  name           String
  description    String
  config         String    // JSON-serialized RuleConfig
  symbols        String    // JSON-serialized string[] (used when poolType = "FIXED")
  poolType       String    @default("FIXED")   // "FIXED" | "DYNAMIC"
  poolFilterCode String?   // JS body returning boolean; used when poolType = "DYNAMIC"
  sessionId      String?   // chat session that created this rule
  isActive       Boolean   @default(true)
  winRate        Float?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  userId         String
  user           User      @relation(fields: [userId], references: [id])
  triggers       Trigger[]
}

model Trigger {
  id          String   @id @default(cuid())
  ruleId      String
  rule        Rule     @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  symbol      String
  signal      String
  price       Float
  quantity    Int?     // suggested order size in shares, for BUY/SELL from actionType "trade" rules
  message     String
  triggeredAt DateTime @default(now())
}

// OHLCV bars at any interval. Stores daily ('1d') and intraday ('1m','5m','15m','30m','1h')
// bars so backtest can iterate at the finest available granularity.
model StockPrice {
  id       String   @id @default(cuid())
  symbol   String
  date     DateTime
  interval String   @default("1d")
  open     Float
  high     Float
  low      Float
  close    Float
  volume   Float

  @@unique([symbol, date, interval])
  @@index([symbol, interval])
}

// Per-symbol metadata (sector, name, dayTradeable, etc.) written by the startup
// seed and ingest jobs. Pool filter code reads from here during backtest so
// the evaluation is fully Redis-free.
model SymbolMeta {
  symbol    String   @id
  data      String   // JSON blob — arbitrary key/value pairs
  updatedAt DateTime @updatedAt
}

// Trade executions reported by the local trading-app CLI (running the user's own
// Fubon Neo API session). The main server never sees Fubon credentials — only the
// resulting order outcome — so this is purely for dashboard visibility.
model TradeActivity {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  ruleId    String?
  ruleName  String?
  symbol    String
  side      String   // "BUY" | "SELL"
  quantity  Int
  price     Float?
  status    String   // "FILLED" | "FAILED" | "SIMULATED"
  orderId   String?
  message   String?
  source    String   @default("LIVE") // "LIVE" | "SIMULATION"
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

model ChatMessage {
  id        String   @id @default(cuid())
  sessionId String
  role      String
  content   String
  createdAt DateTime @default(now())

  @@index([sessionId])
}
