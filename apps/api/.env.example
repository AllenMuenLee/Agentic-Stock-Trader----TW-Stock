DATABASE_URL="file:./dev.db"
REDIS_URL="redis://localhost:6379"
FUGLE_API_KEY=
GOOGLE_API_KEY=
GOOGLE_MODEL=gemma-4-26b-a4b-it
PORT=3001

# URL of the frontend (used for CORS) — no trailing slash
# Local dev:  http://localhost:3000
# Production: https://your-vercel-app.vercel.app  OR  https://stockagent.tw
FRONTEND_URL=http://localhost:3000

JWT_SECRET=change-me-in-production

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=

LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=
# The Bot's "Basic ID" from the Messaging API tab (e.g. "206ktqan") — NOT the
# numeric Channel ID from the Basic settings tab. Enter it WITHOUT the leading "@".
LINE_BOT_BASIC_ID=

DISCORD_BOT_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
# Local dev:  http://localhost:3001/api/bind/discord/callback
# Production: https://your-oracle-backend-domain.com/api/bind/discord/callback
DISCORD_REDIRECT_URI=http://localhost:3001/api/bind/discord/callback
# Discord only allows bots to DM users who share a guild with the bot. The bot
# must be a member of this guild (invite it via the OAuth2 "bot" scope, not
# just the regular invite link). Users are required to join before DMs work.
DISCORD_GUILD_ID=
# A permanent (non-expiring) invite link to DISCORD_GUILD_ID, shown to users.
DISCORD_INVITE_URL=
